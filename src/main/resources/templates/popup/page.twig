<!DOCTYPE html>
<html lang="{{ locale }}">
<head>
	<title>{{ title }}</title>
	<link rel="stylesheet" type="text/css" href="/res/desktop.css?{{ staticHashes['desktop.css'] }}"/>
    {% if customCSSHash is not empty %}<link rel="stylesheet" type="text/css" href="/system/custom_desktop.css?{{ customCSSHash }}"/>{% endif %}
	<meta name="viewport" content="width=device-width, initial-scale=1"/>
	<script>
		var userConfig={{jsConfig | raw}};
		var langKeys={{jsLangKeys | raw}};
		var mobile=false;
	</script>
	<style>
		.js{display: none;}
		.hasJS .js{display: block;}
		html{height: 100%;}
	</style>
</head>
<body class="popupPage">
<script>document.body.classList.add("hasJS");{%if jsRedirect is not null%} window.location="{{jsRedirect}}";{%endif%}</script>
<div class="headerWrap">
	<div class="headerBG"><div class="shadow"></div></div>
<div class="header">
	<div class="logo"><span class="logoInner"><img src="/res/desktop_logo_v1.svg" height="28" width="27" border="0" alt="Smithereen"/>{{serverName}}</span></div>
	{% if currentUser is not null %}
	<div id="headerNav">
		<b>{{ currentUser | name }}</b>
		<a href="/account/logout?csrf={{ csrf }}&oauth={{ queryString | urlencode }}" data-no-al="1">{{ L("log_out") }}</a>
	</div>
	{% endif %}
</div>
</div>
<div class="popupContent">
	{%block content%}{%endblock%}
</div>
<div></div>
<script src="/res/common.js?{{ staticHashes['common.js'] }}"></script>
</body>
</html>